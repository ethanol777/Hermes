# ========================================
# .gitignore — 莫妮卡完整备份
# ========================================

# === 密钥和认证文件（绝不同步） ===
.env
auth.json
auth.lock
channel_directory.json
feishu_seen_message_ids.json

# === 数据库文件（太大且格式不佳，不同步） ===
state.db
state.db-shm
state.db-wal
memory_store.db
memory_store.db-shm
memory_store.db-wal
kanban.db
response_store.db
response_store.db-shm
response_store.db-wal

# === 运行时/临时文件 ===
gateway.lock
gateway.pid
gateway_state.json
processes.json
models_dev_cache.json
ollama_cloud_models_cache.json
.learnings_state.json
.skills_prompt_snapshot.json
.update_check
.tirith-install-failed
debug.log
learn_debug.log
interrupt_debug.log

# === 缓存、日志、临时 ===
cache/
checkpoints/
logs/
hermes/logs/
cron/
!hermes/cron/
audio_cache/
image_cache/
images/
gallery/
tmp/
weixin/

# === 工具/第三方/运行时 ===
bin/
hooks/
sessions/
sandboxes/
pastes/
pairing/
profiles/
output/
hermes-agent/
node/

# === 编译/构建文件 ===
__pycache__/
*.pyc
*.pyo
*.egg-info/

# === 旧数据（同步脚本残留） ===
openviking-*.whl
text_*.json

# === Git ===
.git/

# === 其他 ===
gateway-service/
*.bat
*.vbs
*.lock